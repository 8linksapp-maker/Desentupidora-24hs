---
import { readData } from '../../lib/readData';

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const cc = pluginsConfig?.cookieConsent;
const enabled = cc?.enabled !== false;
const headline = cc?.headline || 'Privacidade e Cookies';
const description = cc?.description || 'Utilizamos cookies para melhorar sua experiência. Ao clicar em "Aceitar", você concorda com nossa política de privacidade.';
const buttonAccept = cc?.buttonAccept || 'Aceitar';
const buttonReject = cc?.buttonReject || 'Ler Política';
const rejectUrl = cc?.rejectUrl || '/privacidade';
const position = cc?.position || 'bottom';
---

{enabled && (
  <div
    id="cookie-banner"
    style={`position: fixed; ${position === 'top' ? 'top: 20px;' : 'bottom: 20px;'} left: 20px; right: 20px; z-index: 9999999; display: flex; justify-content: flex-end; pointer-events: none; opacity: 0; transform: ${position === 'top' ? 'translateY(-20px)' : 'translateY(20px)'}; transition: all 0.5s ease;`}
    data-position={position}
  >
    <div style="background: #ffffff; color: #253041; padding: 25px; border-radius: 15px; box-shadow: 0 10px 50px rgba(0,0,0,0.2); border: 1px solid #e2e8f0; width: 100%; max-width: 400px; pointer-events: auto; display: block !important;">
      <div style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 20px;">
        <div style="width: 45px; height: 45px; border-radius: 12px; background: var(--primary-color, #0052da); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="white"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"
            ></path>
            <path d="M8.5 8.5v.01"></path>
            <path d="M16 15.5v.01"></path>
            <path d="M12 12v.01"></path>
            <path d="M11 17v.01"></path>
            <path d="M7 14v.01"></path>
          </svg>
        </div>
        <div style="flex: 1;">
          <h3
            style="margin: 0 0 4px 0; font-size: 16px; font-weight: 700; color: #1e293b; font-family: sans-serif;"
          >
            Privacidade de Cookies
          </h3>
          <p
            style="margin: 0; font-size: 13px; line-height: 1.5; color: #64748b; font-family: sans-serif;"
          >
            Utilizamos cookies para melhorar sua experiência. Ao continuar, você
            concorda com nossa política.
          </p>
        </div>
      </div>
      <div style="display: flex; gap: 8px; margin-top: 16px;">
        <button
          id="accept-cookies"
          style="flex: 1; padding: 12px; background: var(--primary-color, #0052da); color: #ffffff; border: none; border-radius: 10px; font-weight: 700; font-size: 14px; cursor: pointer; transition: background 0.2s; font-family: sans-serif;"
        >
          Aceitar Tudo
        </button>
        <a
          href={rejectUrl}
          style="flex: 1; padding: 12px; background: #f1f5f9; color: #475569; border: none; border-radius: 10px; font-weight: 700; font-size: 14px; text-decoration: none; text-align: center; transition: background 0.2s; font-family: sans-serif;"
        >
          {buttonReject}
        </a>
      </div>
    </div>
  </div>
)}

<script is:inline>
(function() {
  var banner = document.getElementById('cookie-banner');
  var acceptBtn = document.getElementById('accept-cookies');

  if (!banner || !acceptBtn) {
    console.log('Cookie banner elements not found');
    return;
  }

  // Show if not yet accepted
  if (!localStorage.getItem('cookies-accepted')) {
    console.log('Showing cookie banner...');
    setTimeout(function() {
      banner.style.opacity = '1';
      banner.style.transform = 'translateY(0)';
      banner.style.pointerEvents = 'auto';
    }, 2000);
  }

  acceptBtn.addEventListener('click', function() {
    console.log('Cookies accepted');
    localStorage.setItem('cookies-accepted', 'true');
    banner.style.opacity = '0';
    var isTop = banner.getAttribute('data-position') === 'top';
    banner.style.transform = isTop ? 'translateY(-20px)' : 'translateY(20px)';
    banner.style.pointerEvents = 'none';
    window.dispatchEvent(new CustomEvent('cookies-accepted'));
  });
})();
</script>
